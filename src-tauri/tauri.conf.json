{
  "productName": "Kassandra",
  "version": "0.1.0",
  "identifier": "com.personal-assistant.kassandra",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "cwd": "../client",
      "script": "[ -x node_modules/.bin/vite ] || bun install; bun run dev",
      "wait": false
    },
    "beforeBuildCommand": {
      "cwd": "../client",
      "script": "[ -x node_modules/.bin/vite ] || bun install; bun run build",
      "wait": true
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kassandra",
        "width": 520,
        "height": 800,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
