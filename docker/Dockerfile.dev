FROM rust:1.86-slim-bookworm

# Tauri dependencies (libwebkit2gtk-4.1 for Tauri v2)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    wget \
    unzip \
    libssl-dev \
    libgtk-3-dev \
    libwebkit2gtk-4.1-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    patchelf \
    libasound2-dev \
    libx11-dev \
    libxext-dev \
    libxrandr-dev \
    libxcomposite-dev \
    libxi-dev \
    libxtst-dev \
    libgl1-mesa-dev \
    libglu1-mesa-dev \
    libegl1-mesa-dev \
    mesa-utils \
    gstreamer1.0-alsa \
    gstreamer1.0-plugins-base \
    gstreamer1.0-plugins-good \
    pipewire-alsa \
    && rm -rf /var/lib/apt/lists/*

# Update Rust to latest stable (edition2024 support required by some deps)
RUN rustup update stable && rustup default stable

# Install Bun
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

# Install Tauri CLI via Bun
RUN bun add -g @tauri-apps/cli

# Install cargo-watch for polling-based hot reload in Docker
RUN cargo install cargo-watch

WORKDIR /app
